<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Parent 👋"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#111827"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Here's your family overview"
                    android:textSize="13sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_notifications"
                app:tint="#4F46E5"/>
        </LinearLayout>

        <!-- Children Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Children"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#111827"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_child"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="+ Add"
                android:textSize="12sp"
                app:cornerRadius="8dp"
                app:backgroundTint="#EEF2FF"
                android:textColor="#4F46E5"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_children"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:minHeight="80dp"/>

        <!-- Quick Actions -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="#111827"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.cardview.widget.CardView
                android:id="@+id/card_location"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EEF2FF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_location_pin" app:tint="#4F46E5"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Location" android:textColor="#4F46E5" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_time_limit"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#F0FDF4">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_clock" app:tint="#10B981"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Time Limits" android:textColor="#10B981" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_safe_zones"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFF7ED">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_geofence" app:tint="#F59E0B"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Safe Zones" android:textColor="#F59E0B" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/card_app_controls"
                android:layout_width="0dp"
                android:layout_height="100dp"
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#FFF1F2">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="32dp" android:layout_height="32dp"
                        android:src="@drawable/ic_app_controls" app:tint="#EF4444"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="App Control" android:textColor="#EF4444" android:textStyle="bold" android:textSize="12sp" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
